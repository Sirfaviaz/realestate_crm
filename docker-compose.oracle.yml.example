# Copy to docker-compose.oracle.yml on the VM and fill in secrets.
#   cp docker-compose.oracle.yml.example docker-compose.oracle.yml
#
# Generate secrets:
#   openssl rand -hex 16   # DB password
#   openssl rand -hex 32   # JWT + admin password

services:
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: crm
      POSTGRES_PASSWORD: CHANGE_ME_DB_PASSWORD
      POSTGRES_DB: realestate_crm
    ports:
      - "127.0.0.1:5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U crm -d realestate_crm"]
      interval: 5s
      timeout: 5s
      retries: 10

  backend:
    build: ./backend
    ports:
      - "8000:8000"
    environment:
      DATABASE_URL: postgresql+asyncpg://crm:CHANGE_ME_DB_PASSWORD@db:5432/realestate_crm
      CORS_ORIGINS: https://YOUR-APP.vercel.app,http://localhost:3000
      JWT_SECRET: CHANGE_ME_JWT_SECRET
      DEBUG: "false"
      # Admin-only seed (used by: docker compose ... exec backend python seed.py)
      SEED_MODE: admin
      SEED_ADMIN_EMAIL: you@company.com
      SEED_ADMIN_PASSWORD: CHANGE_ME_ADMIN_PASSWORD
      SEED_ADMIN_NAME: Your Name
      SEED_ADMIN_PHONE: "+919999000001"
    depends_on:
      db:
        condition: service_healthy

volumes:
  pgdata:
